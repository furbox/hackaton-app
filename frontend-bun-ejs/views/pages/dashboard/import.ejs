<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <div class="mb-8">
    <h1 class="text-3xl font-bold text-text-primary">Importar Bookmarks</h1>
    <p class="mt-1 text-text-secondary">Subi el archivo HTML exportado desde tu navegador y traé tus links en segundos.</p>
  </div>

  <% if (errorMessage) { %>
    <div class="mb-6 rounded-xl border border-error/40 bg-error/12 px-4 py-3 text-sm text-error" role="alert">
      <strong class="font-semibold">No pudimos importar:</strong>
      <span><%= errorMessage %></span>
    </div>
  <% } %>

  <% if (summary) { %>
    <div class="mb-6 rounded-xl border border-success/40 bg-success/12 px-4 py-3 text-sm text-success" role="status">
      <strong class="font-semibold">Importación completada.</strong>
      <% if (typeof parsedCount === 'number') { %>
        Procesamos <%= parsedCount %> link<%= parsedCount !== 1 ? 's' : '' %> del archivo.
      <% } %>
    </div>
  <% } %>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <section class="ui-card lg:col-span-2 p-6">
      <h2 class="text-lg font-semibold text-text-primary">Subir archivo de bookmarks</h2>
      <p class="mt-1 text-sm text-text-secondary">Formato aceptado: Netscape Bookmark File (.html) exportado por Chrome o Firefox.</p>

      <form id="import-form" method="POST" action="/dashboard/import" enctype="multipart/form-data" class="mt-5 space-y-4">
        <label id="dropzone" for="bookmarksFile" class="flex cursor-pointer flex-col items-center justify-center rounded-xl border-2 border-dashed border-border bg-slate-900/45 px-6 py-10 text-center transition-colors hover:border-accent-primary/70 hover:bg-accent-primary/10">
          <span class="text-3xl">📁</span>
          <p class="mt-3 text-sm font-medium text-text-primary">Arrastrá tu archivo acá o hacé click para seleccionarlo</p>
          <p class="mt-1 text-xs text-text-secondary">Solo archivos <code>.html</code> o <code>.htm</code></p>
          <p id="selected-file" class="mt-3 hidden rounded-full bg-accent-primary/15 px-3 py-1 text-xs font-medium text-accent-primary"></p>
        </label>

        <input id="bookmarksFile" name="bookmarksFile" type="file" accept=".html,.htm,text/html" class="sr-only" required />

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <button id="submit-btn" type="submit" class="ui-btn-primary inline-flex items-center justify-center gap-2 rounded-lg px-5 py-2.5 text-sm font-medium disabled:cursor-not-allowed disabled:opacity-70">
            <span>Importar bookmarks</span>
          </button>
          <p id="progress-hint" class="hidden text-sm text-text-secondary">Procesando archivo, esto puede tardar unos segundos...</p>
        </div>
      </form>
    </section>

    <aside class="ui-card p-6">
      <h3 class="text-base font-semibold text-text-primary">Cómo exportar</h3>
      <div class="mt-4 space-y-4 text-sm text-text-secondary">
        <div>
          <p class="font-medium text-text-primary">Chrome</p>
          <ol class="mt-1 list-decimal space-y-1 pl-5">
            <li>Abrí el administrador de marcadores.</li>
            <li>Entrá al menú de tres puntos.</li>
            <li>Elegí <em>Exportar marcadores</em>.</li>
          </ol>
        </div>
        <div>
          <p class="font-medium text-text-primary">Firefox</p>
          <ol class="mt-1 list-decimal space-y-1 pl-5">
            <li>Abrí Marcadores &gt; Administrar marcadores.</li>
            <li>Click en <em>Importar y respaldar</em>.</li>
            <li>Seleccioná <em>Exportar marcadores a HTML</em>.</li>
          </ol>
        </div>
      </div>
    </aside>
  </div>

  <% if (summary) { %>
    <section class="ui-card mt-8 p-6">
      <h2 class="text-lg font-semibold text-text-primary">Resumen de importación</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-success/35 bg-success/12 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-success">Importados</p>
          <p class="mt-1 text-2xl font-bold text-success"><%= summary.imported %></p>
        </div>
        <div class="rounded-xl border border-warning/35 bg-warning/12 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-warning">Duplicados</p>
          <p class="mt-1 text-2xl font-bold text-warning"><%= summary.duplicates %></p>
        </div>
        <div class="rounded-xl border border-accent-secondary/35 bg-accent-secondary/12 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wide text-accent-secondary">Categorías creadas</p>
          <p class="mt-1 text-2xl font-bold text-accent-secondary"><%= summary.categoriesCreated %></p>
        </div>
      </div>

      <% if (summary.importedLinks && summary.importedLinks.length > 0) { %>
        <div class="mt-6 overflow-x-auto rounded-xl border border-border">
          <table class="ui-table min-w-full text-sm">
            <thead>
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Título</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">URL</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Categoría</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border bg-surface">
              <% summary.importedLinks.forEach(function(link) { %>
                <tr>
                  <td class="px-4 py-3 font-medium text-text-primary"><%= link.title %></td>
                  <td class="px-4 py-3 text-xs text-text-secondary">
                    <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer" class="font-mono hover:text-accent-primary"><%= link.url %></a>
                  </td>
                  <td class="px-4 py-3 text-text-secondary"><%= link.categoryName || 'Sin categoría' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href="/dashboard/links" class="ui-btn-primary inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-medium">
          Ver mis links
        </a>
        <a href="/dashboard/import" class="ui-btn-secondary inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-medium">
          Importar más
        </a>
      </div>
    </section>
  <% } %>

</div>

<script>
(() => {
  const fileInput = document.getElementById('bookmarksFile');
  const selectedFile = document.getElementById('selected-file');
  const dropzone = document.getElementById('dropzone');
  const form = document.getElementById('import-form');
  const submitBtn = document.getElementById('submit-btn');
  const progressHint = document.getElementById('progress-hint');

  if (!fileInput || !selectedFile || !dropzone || !form || !submitBtn || !progressHint) {
    return;
  }

  const renderFileLabel = () => {
    const file = fileInput.files && fileInput.files.length > 0 ? fileInput.files[0] : null;
    if (!file) {
      selectedFile.classList.add('hidden');
      selectedFile.textContent = '';
      return;
    }

    selectedFile.textContent = `Archivo seleccionado: ${file.name}`;
    selectedFile.classList.remove('hidden');
  };

  fileInput.addEventListener('change', renderFileLabel);

  ['dragenter', 'dragover'].forEach((eventName) => {
    dropzone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropzone.classList.add('border-accent-primary', 'bg-accent-primary/10');
    });
  });

  ['dragleave', 'drop'].forEach((eventName) => {
    dropzone.addEventListener(eventName, (event) => {
      event.preventDefault();
      dropzone.classList.remove('border-accent-primary', 'bg-accent-primary/10');
    });
  });

  dropzone.addEventListener('drop', (event) => {
    const files = event.dataTransfer && event.dataTransfer.files;
    if (!files || files.length === 0) {
      return;
    }

    fileInput.files = files;
    renderFileLabel();
  });

  form.addEventListener('submit', () => {
    submitBtn.setAttribute('disabled', 'true');
    progressHint.classList.remove('hidden');
  });
})();
</script>
