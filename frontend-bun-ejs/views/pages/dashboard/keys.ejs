<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-text-primary">API Keys</h1>
    <p class="mt-1 text-text-secondary">Gestioná tus claves para acceder a la API y al MCP Server</p>
  </div>

  <!-- New key revealed — shown ONCE after creation -->
  <% if (typeof newKey !== 'undefined' && newKey) { %>
    <div class="mb-8 rounded-2xl border border-success/40 bg-success/12 p-5">
      <div class="flex items-start gap-3">
        <span class="text-2xl flex-shrink-0">🔑</span>
        <div class="flex-1 min-w-0">
          <p class="mb-1 font-semibold text-success">¡Tu nueva API Key está lista!</p>
          <p class="mb-3 text-sm text-success/90">
            Esta clave solo se muestra <strong>una vez</strong>. Copiala y guardala en un lugar seguro.
          </p>
          <p class="mb-3 text-xs text-success/80">
            Si salis o recargas esta pagina, no se vuelve a mostrar.
          </p>
          <div class="flex items-center gap-2">
            <code id="new-key-value"
                  class="flex-1 break-all rounded-lg border border-success/35 bg-surface px-4 py-2.5 font-mono text-sm text-text-primary">
              <%= newKey %>
            </code>
            <button onclick="copyKey(event)"
                    class="flex-shrink-0 rounded-lg bg-success px-3 py-2.5 text-sm font-medium text-slate-950 transition-colors hover:bg-emerald-300 whitespace-nowrap">
              📋 Copiar
            </button>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Create form -->
  <div class="ui-card p-6 mb-8">
    <h2 class="mb-4 text-base font-semibold text-text-primary">Crear nueva API Key</h2>
    <form method="POST" action="/dashboard/keys/create"
          class="flex flex-col sm:flex-row gap-3">
      <input type="text" name="name" required placeholder="Nombre (ej: Claude Desktop)"
             class="ui-input flex-1" />
      <select name="permissions"
              class="ui-select">
        <option value="read">Solo lectura</option>
        <option value="read+write">Lectura + Escritura</option>
      </select>
      <button type="submit"
              class="ui-btn-primary whitespace-nowrap px-5 py-2 text-sm font-medium">
        + Generar
      </button>
    </form>
  </div>

  <!-- Keys table -->
  <div class="ui-card overflow-hidden">
    <% if (keys && keys.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="ui-table w-full text-sm">
          <thead>
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Nombre</th>
              <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider">Prefijo</th>
              <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Permisos</th>
              <th class="hidden px-4 py-3 text-left text-xs font-medium uppercase tracking-wider sm:table-cell">Último uso</th>
              <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% keys.forEach(function(apiKey) { %>
              <tr class="ui-table-row">
                <td class="px-6 py-4 font-medium text-text-primary"><%= apiKey.name %></td>
                <td class="px-6 py-4">
                  <code class="rounded border border-border bg-slate-900/60 px-2 py-1 font-mono text-xs text-text-secondary">
                    <%= apiKey.key_prefix %>...
                  </code>
                </td>
                <td class="px-4 py-4">
                  <span class="rounded-full px-2 py-1 text-xs
                    <%= apiKey.permissions === 'read+write' ? 'bg-warning/15 text-warning' : 'bg-accent-primary/15 text-accent-primary' %>">
                    <%= apiKey.permissions %>
                  </span>
                </td>
                <td class="hidden px-4 py-4 text-xs text-text-secondary sm:table-cell">
                  <%= apiKey.last_used_at
                      ? new Date(apiKey.last_used_at).toLocaleDateString('es-AR')
                      : 'Nunca' %>
                </td>
                <td class="px-6 py-4 text-right">
                  <form method="POST" action="/dashboard/keys/<%= apiKey.id %>/delete"
                        onsubmit="return confirm('¿Revocar esta API Key?')">
                    <button type="submit"
                            class="rounded px-2 py-1 text-xs font-medium text-error transition-colors hover:bg-error/10">
                      🗑️ Revocar
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="px-6 py-16 text-center">
        <p class="text-5xl mb-4">🔑</p>
        <p class="mb-2 text-lg font-medium text-text-primary">No tenés API Keys todavía</p>
        <p class="text-text-secondary">Creá una key para conectar tus herramientas de IA</p>
      </div>
    <% } %>
  </div>

</div>

<script>
function copyKey(event) {
  if (!event || !event.target) {
    return;
  }

  const val = document.getElementById('new-key-value').textContent.trim();
  navigator.clipboard.writeText(val).then(() => {
    const btn = event.target;
    const original = btn.textContent;
    btn.textContent = '✅ Copiado';
    setTimeout(() => { btn.textContent = original; }, 2000);
  });
}
</script>
