<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <a href="/dashboard/links"
         class="text-sm font-medium text-text-secondary hover:text-accent-primary transition-colors">
        ← Volver a Mis Links
      </a>
    </div>

    <div class="ui-card p-6 mb-6">
      <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
        <!-- Title and URL -->
        <div class="flex-1 min-w-0">
          <h1 class="text-2xl font-bold text-text-primary mb-2"><%= link.title %></h1>
          <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer"
             class="line-clamp-2 font-mono text-sm text-accent-primary hover:text-cyan-300 transition-colors">
            <%= link.url %>
          </a>
        </div>

        <!-- Shortlink with copy button -->
        <div class="flex items-center gap-2 bg-slate-950/50 rounded-xl px-4 py-2 border border-border">
          <span class="text-sm font-mono text-text-secondary">/<%= link.short_code %></span>
          <button onclick="copyShortLink()"
                  class="ml-2 text-text-secondary hover:text-accent-primary transition-colors"
                  title="Copiar shortlink">
            📋
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
    <div class="ui-card p-6 flex items-center gap-4">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-accent-primary/15 text-3xl">👁️</div>
      <div>
        <p class="text-sm text-text-secondary">Vistas totales</p>
        <p class="text-3xl font-bold text-text-primary"><%= link.totalViews %></p>
      </div>
    </div>

    <div class="ui-card p-6 flex items-center gap-4">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-error/15 text-3xl">❤️</div>
      <div>
        <p class="text-sm text-text-secondary">Likes</p>
        <p class="text-3xl font-bold text-text-primary"><%= link.totalLikes %></p>
      </div>
    </div>

    <div class="ui-card p-6 flex items-center gap-4">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-warning/15 text-3xl">⭐</div>
      <div>
        <p class="text-sm text-text-secondary">Favoritos</p>
        <p class="text-3xl font-bold text-text-primary"><%= link.totalFavorites %></p>
      </div>
    </div>
  </div>

  <!-- Tabs with Alpine.js -->
  <div class="ui-card" x-data="{ activeTab: 'views' }">
    <!-- Tab Navigation -->
    <div class="flex items-center gap-1 border-b border-border px-6">
      <button @click="activeTab = 'views'"
              :class="activeTab === 'views' ? 'text-accent-primary border-accent-primary' : 'text-text-secondary border-transparent hover:text-text-primary'"
              class="px-4 py-4 text-sm font-medium border-b-2 transition-colors">
        👁️ Vistas <%= link.totalViews > 0 ? `(${link.totalViews})` : '' %>
      </button>
      <button @click="activeTab = 'likes'"
              :class="activeTab === 'likes' ? 'text-accent-primary border-accent-primary' : 'text-text-secondary border-transparent hover:text-text-primary'"
              class="px-4 py-4 text-sm font-medium border-b-2 transition-colors">
        ❤️ Likes <%= link.totalLikes > 0 ? `(${link.totalLikes})` : '' %>
      </button>
      <button @click="activeTab = 'favorites'"
              :class="activeTab === 'favorites' ? 'text-accent-primary border-accent-primary' : 'text-text-secondary border-transparent hover:text-text-primary'"
              class="px-4 py-4 text-sm font-medium border-b-2 transition-colors">
        ⭐ Favoritos <%= link.totalFavorites > 0 ? `(${link.totalFavorites})` : '' %>
      </button>
    </div>

    <!-- Tab Content: Views -->
    <div x-show="activeTab === 'views'" x-transition class="p-6">
      <% if (link.views && link.views.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="ui-table w-full text-sm">
            <thead>
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">Fecha</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider">IP</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider hidden sm:table-cell">User Agent</th>
              </tr>
            </thead>
            <tbody>
              <% link.views.forEach(function(view) { %>
                <tr class="ui-table-row">
                  <td class="px-4 py-3 text-text-primary">
                    <%= link.formatDate(view.visitedAt) %>
                  </td>
                  <td class="px-4 py-3 font-mono text-xs text-text-secondary">
                    <%= link.anonymizeIP(view.ipAddress) %>
                  </td>
                  <td class="px-4 py-3 text-text-secondary hidden sm:table-cell">
                    <div class="max-w-xs truncate" title="<%= view.userAgent %>">
                      <%= view.userAgent %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="py-16 text-center">
          <p class="text-5xl mb-4">👁️</p>
          <p class="mb-2 text-lg font-medium text-text-primary">Sin vistas aún</p>
          <p class="text-text-secondary">Este link aún no ha recibido visitas</p>
        </div>
      <% } %>
    </div>

    <!-- Tab Content: Likes -->
    <div x-show="activeTab === 'likes'" x-transition class="p-6" style="display: none;">
      <% if (link.likes && link.likes.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% link.likes.forEach(function(likeUser) { %>
            <div class="flex items-center gap-3 p-4 rounded-xl bg-slate-900/30 border border-border hover:border-accent-primary/30 transition-colors">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-primary/15 overflow-hidden">
                <% if (likeUser.avatarUrl && likeUser.avatarUrl.startsWith('http')) { %>
                  <img src="<%= likeUser.avatarUrl %>" alt="<%= likeUser.username %>"
                       class="h-10 w-10 rounded-full object-cover">
                <% } else { %>
                  <span class="text-lg"><%= link.getAvatarDisplay(likeUser.avatarUrl, likeUser.username) %></span>
                <% } %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-medium text-text-primary truncate"><%= likeUser.username %></p>
                <p class="text-xs text-text-secondary"><%= link.formatDate(likeUser.createdAt) %></p>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="py-16 text-center">
          <p class="text-5xl mb-4">❤️</p>
          <p class="mb-2 text-lg font-medium text-text-primary">Sin likes aún</p>
          <p class="text-text-secondary">Este link aún no ha recibido likes</p>
        </div>
      <% } %>
    </div>

    <!-- Tab Content: Favorites -->
    <div x-show="activeTab === 'favorites'" x-transition class="p-6" style="display: none;">
      <% if (link.favorites && link.favorites.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% link.favorites.forEach(function(favUser) { %>
            <div class="flex items-center gap-3 p-4 rounded-xl bg-slate-900/30 border border-border hover:border-accent-primary/30 transition-colors">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-warning/15 overflow-hidden">
                <% if (favUser.avatarUrl && favUser.avatarUrl.startsWith('http')) { %>
                  <img src="<%= favUser.avatarUrl %>" alt="<%= favUser.username %>"
                       class="h-10 w-10 rounded-full object-cover">
                <% } else { %>
                  <span class="text-lg"><%= link.getAvatarDisplay(favUser.avatarUrl, favUser.username) %></span>
                <% } %>
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-medium text-text-primary truncate"><%= favUser.username %></p>
                <p class="text-xs text-text-secondary"><%= link.formatDate(favUser.createdAt) %></p>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="py-16 text-center">
          <p class="text-5xl mb-4">⭐</p>
          <p class="mb-2 text-lg font-medium text-text-primary">Sin favoritos aún</p>
          <p class="text-text-secondary">Este link aún no ha sido guardado como favorito</p>
        </div>
      <% } %>
    </div>
  </div>

</div>

<script>
function copyShortLink() {
  const shortLink = window.location.origin + '/<%= link.short_code %>';
  navigator.clipboard.writeText(shortLink).then(() => {
    // Show a simple toast notification
    const toast = document.createElement('div');
    toast.className = 'fixed bottom-4 right-4 ui-card px-4 py-2 text-sm text-success flex items-center gap-2 z-50';
    toast.innerHTML = '<span>✓</span><span>¡Copiado!</span>';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2000);
  }).catch(err => {
    console.error('Failed to copy:', err);
  });
}
</script>
