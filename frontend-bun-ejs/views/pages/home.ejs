<!-- Hero Section -->
<section class="bg-gradient-to-br from-bg via-surface to-slate-950 py-20 px-4">
  <div class="max-w-4xl mx-auto text-center">

    <!-- Badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-accent-primary/15 px-4 py-1.5 text-sm font-medium text-accent-primary">
      <span>✨</span>
      <span>Hackathon 2026 midudev</span>
    </div>

    <!-- Headline -->
    <h1 class="mb-6 text-4xl font-extrabold leading-tight text-text-primary sm:text-5xl lg:text-6xl">
      <%= headline %>
    </h1>

    <!-- Subtitle -->
    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-text-secondary sm:text-xl">
      <%= subtitle %>
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/auth/register"
         class="ui-btn-primary w-full px-8 py-3.5 text-lg font-semibold transition-all duration-200 sm:w-auto">
        Empezar gratis
      </a>
      <a href="/explore"
         class="ui-btn-secondary w-full px-8 py-3.5 text-lg font-semibold transition-all duration-200 sm:w-auto">
        Explorar links publicos
      </a>
    </div>

  </div>
</section>

<!-- Problem + Solution -->
<section class="bg-bg py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <article class="ui-card p-6 sm:p-8">
        <p class="mb-3 inline-flex rounded-full bg-warning/15 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-warning">
          Problema
        </p>
        <h2 class="mb-3 text-2xl font-bold text-text-primary">Tus links estan por todos lados</h2>
        <p class="text-sm leading-relaxed text-text-secondary sm:text-base">
          Notas rapidas, chats, favoritos del navegador y docs sueltos. Cuando necesitas algo importante,
          perdes tiempo buscando en cinco lugares distintos.
        </p>
      </article>

      <article class="ui-card p-6 sm:p-8 border-accent-primary/40">
        <p class="mb-3 inline-flex rounded-full bg-success/15 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-success">
          Solucion URLoft
        </p>
        <h2 class="mb-3 text-2xl font-bold text-text-primary">Una sola biblioteca, con control total</h2>
        <p class="text-sm leading-relaxed text-text-secondary sm:text-base">
          URLoft centraliza todos tus enlaces, permite busqueda full-text real y te deja decidir si cada link
          es publico o privado segun el contexto.
        </p>
      </article>
    </div>
  </div>
</section>

<!-- Stats Section (real data) -->
<section class="border-y border-border bg-surface py-16 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center text-white">
      <div>
        <div class="text-4xl font-extrabold mb-1"><%= stats.totalUsers %></div>
        <div class="font-medium text-text-secondary">Usuarios</div>
      </div>
      <div>
        <div class="text-4xl font-extrabold mb-1"><%= stats.totalLinks %></div>
        <div class="font-medium text-text-secondary">Links guardados</div>
      </div>
      <div>
        <div class="text-4xl font-extrabold mb-1"><%= stats.totalCategories %></div>
        <div class="font-medium text-text-secondary">Categorias</div>
      </div>
    </div>
  </div>
</section>

<!-- Featured Links -->
<% if (featuredLinks && featuredLinks.length > 0) { %>
<section class="bg-bg py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-text-primary">Links destacados</h2>
      <a href="/explore" class="text-sm font-medium text-accent-primary transition-colors hover:text-cyan-300">
        Ver todos →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% featuredLinks.forEach(function(link) { %>
        <%- include('../partials/link-card', { link: link }) %>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

