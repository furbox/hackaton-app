<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
     x-data="{
       selectedVideo: null,

       openVideo(video) {
         this.selectedVideo = video;
       },

       closeVideo() {
         this.selectedVideo = null;
       }
     }">

  <!-- Page header -->
  <div class="mb-8">
    <h1 class="mb-1 text-3xl font-bold text-text-primary"><%= hero?.title || 'Cómo lo hice' %></h1>
    <p class="text-text-secondary"><%= hero?.description || '' %></p>
  </div>

  <!-- Main/Featured video (always shows first video) -->
  <% if (mainVideo) { %>
    <div class="mb-12">
      <div class="ui-card overflow-hidden">
        <div class="aspect-video w-full bg-slate-900">
          <lite-youtube
            videoid="<%= mainVideo.videoId %>"
            class="w-full h-full">
          </lite-youtube>
        </div>
        <div class="p-6">
          <h2 class="text-2xl font-bold text-text-primary mb-2"><%= mainVideo.title %></h2>
          <p class="text-text-secondary"><%= mainVideo.description %></p>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Videos grid -->
  <% if (restVideos && restVideos.length > 0) { %>
    <div>
      <h2 class="text-2xl font-bold text-text-primary mb-6">Más videos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% restVideos.forEach(function(video) { %>
          <div @click="openVideo(<%= JSON.stringify(video) %>)"
               class="ui-card overflow-hidden cursor-pointer group hover:border-accent-primary/60 transition-all duration-200">
            <!-- Thumbnail with play button overlay -->
            <div class="relative aspect-video bg-slate-900 overflow-hidden">
              <img
                src="https://img.youtube.com/vi/<%= video.videoId %>/maxresdefault.jpg"
                alt="<%= video.title %>"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
              />
              <!-- Play button overlay -->
              <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/50 transition-colors">
                <div class="w-16 h-16 bg-accent-primary rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-8 h-8 text-slate-950 ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <!-- Duration badge -->
              <% if (video.duration) { %>
                <span
                  class="absolute bottom-2 right-2 px-2 py-1 bg-black/80 text-white text-xs font-medium rounded">
                  <%= video.duration %>
                </span>
              <% } %>
            </div>

            <!-- Video info -->
            <div class="p-4">
              <h3 class="font-semibold text-text-primary mb-1 group-hover:text-accent-primary transition-colors"><%= video.title %></h3>
              <p class="text-sm text-text-secondary line-clamp-2"><%= video.description %></p>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Empty state -->
  <% if (!mainVideo) { %>
    <div class="py-20 text-center">
      <div class="text-5xl mb-4">🎬</div>
      <p class="text-lg font-medium text-text-primary">No hay videos disponibles</p>
      <p class="text-sm mt-2 text-text-secondary">Pronto estarán disponibles los videos del proceso de desarrollo.</p>
    </div>
  <% } %>

  <!-- Video modal/overlay -->
  <div x-show="selectedVideo" x-cloak
       @click.self="closeVideo()"
       @keydown.escape.window="closeVideo()"
       class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 p-4 sm:p-6"
       style="display: none;"
       role="dialog"
       aria-modal="true"
       aria-labelledby="modal-title">
    <div class="relative w-full max-w-5xl">
      <!-- Close button -->
      <button @click="closeVideo()"
              class="absolute -top-12 right-0 text-white/80 hover:text-white transition-colors p-2"
              aria-label="Close modal">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Video embed -->
      <div class="aspect-video bg-slate-900 rounded-lg overflow-hidden shadow-2xl">
        <iframe x-show="selectedVideo?.videoId"
               :src="`https://www.youtube.com/embed/${selectedVideo.videoId}?autoplay=1`"
               class="w-full h-full"
               frameborder="0"
               allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
               allowfullscreen>
        </iframe>
      </div>

      <!-- Video info in modal -->
      <div class="mt-4 bg-surface rounded-lg p-4">
        <h3 id="modal-title" class="text-xl font-bold text-text-primary" x-text="selectedVideo?.title"></h3>
        <p class="text-text-secondary mt-1" x-text="selectedVideo?.description"></p>
      </div>
    </div>
  </div>

</div>
