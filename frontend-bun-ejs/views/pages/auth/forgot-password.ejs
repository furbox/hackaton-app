<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <!-- Card -->
    <div class="ui-card p-8">

      <!-- Header -->
      <div class="text-center mb-8">
        <img
          src="/public/logo-urloft.png"
          alt="URLoft logo"
          class="mx-auto mb-3 h-14 w-14 rounded-2xl border border-border/80 bg-slate-950/40 object-cover p-1 shadow-lg shadow-black/35"
        />
        <h1 class="text-2xl font-bold text-text-primary">Recuperar contraseña</h1>
        <p class="mt-1 text-sm leading-relaxed text-text-secondary">
          Ingresá tu email y te enviaremos instrucciones para recuperar el acceso.
        </p>
      </div>

      <!-- Form -->
      <form method="POST" action="/auth/forgot-password" class="space-y-5">

        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-text-secondary">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="tu@email.com"
            class="ui-input"
          />
        </div>

        <button
          type="submit"
          class="ui-btn-primary w-full py-3 text-sm">
          Enviar instrucciones
        </button>

      </form>

      <!-- Footer -->
      <p class="mt-6 text-center text-sm text-text-secondary">
        <a href="/auth/login" class="font-medium text-accent-primary transition-colors hover:text-cyan-300">
          ← Volver al login
        </a>
      </p>

    </div>
  </div>
</div>
