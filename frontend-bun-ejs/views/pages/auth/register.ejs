<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <!-- Card -->
    <div class="ui-card p-8">

      <!-- Header -->
      <div class="text-center mb-8">
        <a href="/" aria-label="URLoft home" class="inline-block mb-3">
          <img
            src="/public/logo-urloft.png"
            alt="URLoft logo"
            class="h-9 w-auto object-contain object-center"
          />
        </a>
        <h1 class="text-2xl font-bold text-text-primary">Crear cuenta</h1>
        <p class="mt-1 text-sm text-text-secondary">Empezá a guardar tus links con superpoderes</p>
      </div>

      <!-- Form -->
      <form method="POST" action="/auth/register" class="space-y-5">

        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-text-secondary">
            Pseudónimo
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="tu-usuario"
            class="ui-input"
          />
        </div>

        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-text-secondary">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="tu@email.com"
            class="ui-input"
          />
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-text-secondary">
            Contraseña
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="new-password"
            placeholder="Mínimo 8 caracteres"
            minlength="8"
            class="ui-input"
          />
        </div>

        <button
          type="submit"
          class="ui-btn-primary w-full py-3 text-sm">
          Crear cuenta gratis
        </button>

      </form>

      <!-- Footer -->
      <p class="mt-6 text-center text-sm text-text-secondary">
        ¿Ya tenés cuenta?
        <a href="/auth/login" class="font-medium text-accent-primary transition-colors hover:text-cyan-300">
          Iniciá sesión
        </a>
      </p>

    </div>
  </div>
</div>
