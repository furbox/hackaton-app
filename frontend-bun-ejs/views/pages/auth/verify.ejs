<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md text-center">

    <% if (verified) { %>
      <!-- Success -->
      <div class="text-6xl mb-4">✅</div>
      <h1 class="mb-3 text-2xl font-bold text-text-primary">¡Email verificado!</h1>
      <p class="mb-8 text-sm leading-relaxed text-text-secondary">
        <%= message %>
      </p>
      <a href="/auth/login"
         class="ui-btn-primary inline-block px-8 py-3 text-sm">
        Iniciar sesión →
      </a>
    <% } else { %>
      <!-- Error -->
      <div class="text-6xl mb-4">❌</div>
      <h1 class="mb-3 text-2xl font-bold text-text-primary">Token inválido</h1>
      <p class="mb-8 text-sm leading-relaxed text-text-secondary">
        <%= message %>
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/auth/login"
           class="ui-btn-primary inline-block px-8 py-3 text-sm">
          Ir al login
        </a>
        <a href="/auth/register"
           class="ui-btn-secondary inline-block px-8 py-3 text-sm">
          Crear cuenta
        </a>
      </div>
    <% } %>

  </div>
</div>
