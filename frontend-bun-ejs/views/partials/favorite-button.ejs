<%
  const rawSuffix = typeof idSuffix === "string" ? idSuffix.trim() : "";
  const safeSuffix = rawSuffix.replace(/[^a-zA-Z0-9_-]/g, "").slice(0, 40);
  const suffixSegment = safeSuffix.length > 0 ? `-${safeSuffix}` : "";
  const suffixQuery = safeSuffix.length > 0 ? `?idSuffix=${encodeURIComponent(safeSuffix)}` : "";
%>
<span id="fav-<%= linkId %><%= suffixSegment %>">
  <button
    hx-post="/links/<%= linkId %>/favorite<%= suffixQuery %>"
    hx-target="#fav-<%= linkId %><%= suffixSegment %>"
    hx-swap="outerHTML"
    hx-trigger="click"
    hx-indicator="#fav-loading-<%= linkId %><%= suffixSegment %>"
    aria-label="<%= favorited ? 'Quitar guardado' : 'Guardar' %>"
    class="inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-sm font-medium transition-colors
           <%= favorited ? 'border-accent-secondary/50 bg-accent-secondary/15 text-accent-secondary hover:bg-accent-secondary/20' : 'border-border bg-slate-900/50 text-text-secondary hover:border-accent-primary/40 hover:text-text-primary' %>
           focus:outline-none focus:ring-2 focus:ring-accent-primary focus:ring-offset-1"
  >
    <% if (favorited) { %>
      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
      </svg>
    <% } else { %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
      </svg>
    <% } %>
    <span><%= count %></span>
    <span id="fav-loading-<%= linkId %><%= suffixSegment %>" class="htmx-indicator inline-flex items-center text-xs text-text-secondary/70" aria-hidden="true">...</span>
  </button>
</span>
