<%
  /**
   * Partial: link-row-simple.ejs
   *
   * Renders a single table row for a link with:
   * - Title with visibility badge (colorful)
   * URL
   * - Views count (👁)
   * - Likes count (❤️)
   * - Favorites count (⭐)
   * - Actions (link to manage)
   * - Category badge if present (with custom color)
   *
   * Variables:
   * @param {Object} link - The link object
   * @param {boolean} showActions - Whether to show edit/delete actions (default: false for simple view)
   */

  // Normalize visibility boolean (handle both is_public and isPublic, string or boolean)
  const visibilityRaw = link.is_public ?? link.isPublic;
  const isPublic = visibilityRaw === true || visibilityRaw === 'true';

  // Normalize counts (handle both snake_case and camelCase)
  const views = link.views || 0;
  const likesCount = link.likes_count ?? link.likesCount ?? 0;
  const favoritesCount = link.favorites_count ?? link.favoritesCount ?? 0;
%>

<tr class="ui-table-row">
  <td class="px-6 py-4">
    <div class="mb-0.5 line-clamp-1 font-medium text-text-primary"><%= link.title %></div>
    <a href="<%= link.url %>" target="_blank" rel="noopener noreferrer"
       class="line-clamp-1 font-mono text-xs text-text-secondary transition-colors hover:text-accent-primary">
      <%= link.url %>
    </a>
    <% if (link.category && link.category.name) { %>
      <span class="inline-block mt-1 text-xs px-2 py-0.5 rounded-full text-white"
            style="background-color: <%= link.category.color || '#6366f1' %>">
        <%= link.category.name %>
      </span>
    <% } %>
  </td>
  <td class="px-4 py-4 text-center hidden sm:table-cell">
    <span class="rounded-full px-2 py-1 text-xs <%= isPublic ? 'bg-success/15 text-success' : 'bg-slate-900/60 text-text-secondary' %>">
      <%= isPublic ? 'público' : 'privado' %>
    </span>
  </td>
  <td class="px-4 py-4 text-center text-text-secondary"><%= views %></td>
  <td class="px-4 py-4 text-center text-text-secondary"><%= likesCount %></td>
  <td class="px-4 py-4 text-center text-text-secondary"><%= favoritesCount %></td>
  <td class="px-6 py-4 text-right">
    <% if (showActions) { %>
      <div class="flex items-center justify-end gap-2">
        <!-- Stats button -->
        <a href="/dashboard/links/<%= link.id %>"
           class="rounded px-2 py-1 text-xs font-medium text-accent-secondary transition-colors hover:bg-accent-secondary/10">
          📊 Stats
        </a>
        <!-- Edit button -->
        <button onclick="openEditModal(<%= JSON.stringify(link) %>)"
                class="rounded px-2 py-1 text-xs font-medium text-accent-primary transition-colors hover:bg-accent-primary/10 hover:text-cyan-300">
          ✏️ Editar
        </button>
        <!-- Delete button -->
        <form method="POST" action="/dashboard/links/<%= link.id %>/delete"
              onsubmit="return confirm('¿Eliminar este link?')">
          <button type="submit"
                  class="rounded px-2 py-1 text-xs font-medium text-error transition-colors hover:bg-error/10">
            🗑️ Eliminar
          </button>
        </form>
      </div>
    <% } else { %>
      <a href="/dashboard/links" class="text-xs font-medium text-accent-primary hover:text-cyan-300">
        Gestionar →
      </a>
    <% } %>
  </td>
</tr>
