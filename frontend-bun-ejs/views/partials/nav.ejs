<nav class="sticky top-0 z-50 border-b border-border bg-surface/85 backdrop-blur" x-data="{ mobileMenuOpen: false }">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Brand -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-2xl">🔗</span>
        <span class="text-xl font-bold text-accent-primary group-hover:text-cyan-300 transition-colors">
          URLoft
        </span>
      </a>

      <!-- Desktop Nav links -->
      <div class="hidden md:flex items-center gap-6">
        <a href="/" class="text-text-secondary hover:text-text-primary font-medium transition-colors">
          Home
        </a>
        <a href="/explore" class="text-text-secondary hover:text-text-primary font-medium transition-colors">
          Explore
        </a>
      </div>

      <!-- Desktop Auth area -->
      <div class="hidden md:flex items-center gap-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <!-- Authenticated: show username + dashboard link + logout -->
          <a href="/dashboard"
             class="text-text-secondary hover:text-text-primary font-medium text-sm transition-colors hidden sm:block">
            Dashboard
          </a>
          <a href="/dashboard/import"
             class="text-text-secondary hover:text-text-primary font-medium text-sm transition-colors hidden sm:block">
            Importar
          </a>
          <a href="/dashboard/keys"
             class="text-text-secondary hover:text-text-primary font-medium text-sm transition-colors hidden sm:block">
            API Keys
          </a>
          <span class="text-text-secondary/70 hidden sm:block">|</span>
          <span class="text-sm font-medium text-text-primary hidden sm:block">
            👤 <%= user.username %>
          </span>
          <form method="POST" action="/auth/logout" class="inline">
            <button type="submit"
                    class="rounded-lg border border-border bg-slate-900/60 px-4 py-2 text-sm font-medium text-text-primary transition-colors hover:border-accent-primary/60 hover:bg-slate-900">
              Salir
            </button>
          </form>
        <% } else { %>
          <!-- Guest: show Login + Register -->
          <a href="/auth/login"
             class="text-text-secondary hover:text-text-primary font-medium text-sm transition-colors hidden sm:block">
            Iniciar sesión
          </a>
          <a href="/auth/register"
             class="rounded-lg bg-accent-primary px-4 py-2 text-sm font-semibold text-slate-950 transition-colors hover:bg-cyan-300">
            Registrarse
          </a>
        <% } %>
      </div>

      <!-- Mobile menu button -->
      <button
        @click="mobileMenuOpen = !mobileMenuOpen"
        class="md:hidden p-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary transition-colors"
        aria-label="Toggle menu">
        <svg x-show="!mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg x-show="mobileMenuOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display: none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- Mobile menu dropdown -->
  <div x-show="mobileMenuOpen"
       @click.away="mobileMenuOpen = false"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-2"
       class="md:hidden border-t border-border bg-surface shadow-xl shadow-black/30"
       style="display: none;">
    <div class="px-4 py-3 space-y-2">
      <!-- Nav links -->
      <a href="/"
         class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
        Home
      </a>
      <a href="/explore"
         class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
        Explore
      </a>

      <hr class="my-2 border-border">

      <% if (typeof user !== 'undefined' && user) { %>
        <!-- Authenticated: dashboard + logout -->
        <a href="/dashboard"
           class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
          Dashboard
        </a>
        <a href="/dashboard/import"
           class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
          Importar bookmarks
        </a>
        <a href="/dashboard/keys"
           class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
          API Keys
        </a>
        <div class="px-3 py-2 text-sm text-text-primary">
          👤 <%= user.username %>
        </div>
        <form method="POST" action="/auth/logout">
          <button type="submit"
                  class="w-full text-left px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
            Salir
          </button>
        </form>
      <% } else { %>
        <!-- Guest: Login + Register -->
        <a href="/auth/login"
           class="block px-3 py-2 rounded-lg text-text-secondary hover:bg-slate-900/80 hover:text-text-primary font-medium transition-colors">
          Iniciar sesión
        </a>
        <a href="/auth/register"
           class="block px-3 py-2 rounded-lg bg-accent-primary hover:bg-cyan-300 text-center font-semibold text-slate-950 transition-colors">
          Registrarse
        </a>
      <% } %>
    </div>
  </div>
</nav>
