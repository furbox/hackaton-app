<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="URLoft — Tu gestor de enlaces con superpoderes" />
  <link rel="icon" type="image/png" sizes="16x16" href="/public/icons/icon-16.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/public/icons/icon-48.png" />
  <link rel="apple-touch-icon" sizes="128x128" href="/public/icons/icon-128.png" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="URLoft" />
  <meta property="og:description" content="URLoft — Tu gestor de enlaces con superpoderes" />
  <meta property="og:image" content="/public/logo-urloft.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="URLoft" />
  <meta name="twitter:description" content="URLoft — Tu gestor de enlaces con superpoderes" />
  <meta name="twitter:image" content="/public/logo-urloft.png" />
  <title><%= title %> - URLoft</title>

  <!-- Tailwind CSS Browser v4 -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <style type="text/tailwindcss">
    @theme {
      --color-bg: #0E1116;
      --color-surface: #151A22;
      --color-border: #2A3342;
      --color-text-primary: #E6ECF2;
      --color-text-secondary: #A5B0BF;
      --color-accent-primary: #4CC9F0;
      --color-accent-secondary: #8B74FF;
      --color-success: #3ECF8E;
      --color-warning: #F4B740;
      --color-error: #FF6B6B;
    }

    @layer base {
      body {
        @apply antialiased bg-bg text-text-primary;
      }

      a {
        @apply text-accent-primary transition-colors;
      }

      a:hover {
        @apply text-cyan-300;
      }

      *:focus-visible {
        outline: 2px solid #4CC9F0;
        outline-offset: 2px;
      }

      ::selection {
        background: #4CC9F033;
        color: #E6ECF2;
      }
    }

    @layer components {
      .ui-card {
        @apply rounded-2xl border border-border bg-surface shadow-lg shadow-black/20;
      }

      .ui-input {
        @apply w-full rounded-xl border border-border bg-slate-950/30 px-4 py-2.5 text-sm text-text-primary placeholder:text-text-secondary/70 transition-colors focus:border-accent-primary;
      }

      .ui-select {
        @apply rounded-xl border border-border bg-slate-950/30 px-4 py-2.5 text-sm text-text-primary transition-colors focus:border-accent-primary;
      }

      .ui-textarea {
        @apply w-full rounded-xl border border-border bg-slate-950/30 px-4 py-2.5 text-sm text-text-primary placeholder:text-text-secondary/70 transition-colors focus:border-accent-primary;
      }

      .ui-btn-primary {
        @apply inline-flex items-center justify-center rounded-xl bg-accent-primary px-5 py-2.5 text-sm font-semibold text-slate-950 transition-colors hover:bg-cyan-300;
      }

      .ui-btn-secondary {
        @apply inline-flex items-center justify-center rounded-xl border border-border bg-slate-900/50 px-5 py-2.5 text-sm font-medium text-text-primary transition-colors hover:border-accent-primary/60 hover:bg-slate-900;
      }

      .ui-btn-ghost {
        @apply inline-flex items-center justify-center rounded-xl border border-border bg-transparent px-4 py-2.5 text-sm font-medium text-text-secondary transition-colors hover:text-text-primary hover:border-accent-primary/50;
      }

      .ui-table thead {
        @apply bg-slate-900/60;
      }

      .ui-table thead th {
        @apply text-text-secondary;
      }

      .ui-table tbody {
        @apply divide-y divide-border;
      }

      .ui-table-row {
        @apply transition-colors hover:bg-slate-900/40;
      }
    }
  </style>

  <!-- PWA -->
  <link rel="manifest" href="/public/manifest.json">
  <meta name="theme-color" content="#6366f1">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="URLoft">
  <link rel="apple-touch-icon" href="/public/icons/icon-192.png">
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/' })
          .then(reg => console.log('SW registered:', reg.scope))
          .catch(err => console.warn('SW registration failed:', err));
      });
    }
  </script>
</head>
<body class="min-h-full flex flex-col">

  <!-- Flash messages -->
  <%- include('../partials/flash') %>

  <!-- Navigation -->
  <%- include('../partials/nav') %>

  <!-- Main content -->
  <main class="flex-1">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="mt-16 border-t border-border bg-surface/70 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center" aria-label="URLoft">
          <img
            src="/public/logo-urloft.png"
            alt="URLoft logo"
            class="h-9 w-auto object-contain object-center"
          />
        </div>
        <p class="text-sm text-text-secondary">
          Hecho con ❤️ para el Hackathon 2026 midudev
        </p>
      </div>
    </div>
  </footer>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>

  <!-- Lite YouTube (YouTube embed ligero) -->
  <script type="module" src="https://cdn.jsdelivr.net/npm/@justinribeiro/lite-youtube@1/lite-youtube.min.js"></script>

  <!-- HTMX -->
  <script src="https://unpkg.com/htmx.org@2.0.8"></script>

  <!-- GLightbox (Lightbox para imágenes) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css">
  <script src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js"></script>

  <!-- Inicializar GLightbox -->
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const lightbox = GLightbox({
        selector: '.glightbox',
        openEffect: 'zoom',
        closeEffect: 'fade',
        width: '1200px',
        height: 'auto',
        zoomable: true,
        draggable: true,
      });
    });
  </script>
</body>
</html>
