<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : 'URLoft — Tu gestor de enlaces con superpoderes' %>" />
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://urloft.site/' %>" />
  <link rel="alternate" hreflang="es" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://urloft.site/' %>" />
  <% if (typeof noindex !== 'undefined' && noindex) { %><meta name="robots" content="noindex, nofollow"><% } %>
  <link rel="icon" type="image/png" sizes="16x16" href="/public/icons/icon-16.png" />
  <link rel="icon" type="image/png" sizes="48x48" href="/public/icons/icon-48.png" />
  <link rel="apple-touch-icon" sizes="128x128" href="/public/icons/icon-128.png" />
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'URLoft' %>" />
  <meta property="og:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) || (typeof pageDescription !== 'undefined' && pageDescription) || 'URLoft — Tu gestor de enlaces con superpoderes' %>" />
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://urloft.site/public/logo-urloft.png' %>" />
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://urloft.site/' %>" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'URLoft' %>" />
  <meta name="twitter:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) || (typeof pageDescription !== 'undefined' && pageDescription) || 'URLoft — Tu gestor de enlaces con superpoderes' %>" />
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://urloft.site/public/logo-urloft.png' %>" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="URLoft" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : (typeof title !== 'undefined' ? title + ' - URLoft' : 'URLoft') %></title>

  <!-- Tailwind CSS -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="stylesheet" href="/public/styles.css">

  <!-- PWA -->
  <link rel="manifest" href="/public/manifest.json">
  <meta name="theme-color" content="#6366f1">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="URLoft">
  <link rel="apple-touch-icon" href="/public/icons/icon-192.png">
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/' })
          .then(reg => console.log('SW registered:', reg.scope))
          .catch(err => console.warn('SW registration failed:', err));
      });
    }
  </script>
  <% if (typeof jsonld !== 'undefined' && jsonld) { %>
  <script type="application/ld+json"><%- jsonld %></script>
  <% } %>
</head>
<body class="min-h-full flex flex-col">

  <!-- Flash messages -->
  <%- include('../partials/flash') %>

  <!-- Navigation -->
  <%- include('../partials/nav') %>

  <!-- Main content -->
  <main class="flex-1">
    <%- body %>
  </main>

  <!-- Footer -->
  <%- include('../partials/footer') %>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>

  <!-- Lite YouTube (YouTube embed ligero) -->
  <script type="module" src="https://cdn.jsdelivr.net/npm/@justinribeiro/lite-youtube@1/lite-youtube.min.js"></script>

  <!-- HTMX -->
  <script defer src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>

  <!-- GLightbox (Lightbox para imágenes) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/js/glightbox.min.js"></script>

  <!-- Inicializar GLightbox -->
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const lightbox = GLightbox({
        selector: '.glightbox',
        openEffect: 'zoom',
        closeEffect: 'fade',
        width: '1200px',
        height: 'auto',
        zoomable: true,
        draggable: true,
      });
    });
  </script>
</body>
</html>
