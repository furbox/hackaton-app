# Server Configuration
PORT=3000
HOST=localhost

# Database
DATABASE_URL=./db/database.sqlite

# Authentication (JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
FINGERPRINT_STRICT=true

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@urloft.site

# Short Links
BASE_URL=http://localhost:3000
SHORT_PREFIX=s

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-better-auth-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000
# Public frontend origin used for email links (verify/reset-password)
FRONTEND_URL=http://localhost:5173
TRUST_PROXY=false

# API Keys
API_KEY_PREFIX=urlk
API_RATE_LIMIT=100
