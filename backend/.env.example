# Server Configuration
PORT=3000
HOST=localhost

# Database
DATABASE_URL=./db/database.sqlite

# Authentication (JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
FINGERPRINT_STRICT=true

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@urloft.site

# Short Links
BASE_URL=http://localhost:3000
SHORT_PREFIX=s

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-better-auth-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# API Keys
API_KEY_PREFIX=urlk
API_RATE_LIMIT=100

# Public frontend origin used for email links (verify/reset-password)
FRONTEND_URL=http://localhost:5173

# Trust Proxy Headers
# Set to 'true' when behind a reverse proxy (Cloudflare, Nginx, AWS ALB, etc.)
# When enabled, extracts real IP from: x-forwarded-for, x-real-ip
# WARNING: Only enable if your proxy strips/replaces these headers
# Never enable on direct internet exposure without a trusted proxy
TRUST_PROXY=false

# Workers Background Jobs
WORKER_SWEEP_ENABLED=false
WORKER_SWEEP_INTERVAL_MS=300000
HEALTH_CHECK_BATCH_SIZE=50

# Worker Timeouts
HEALTH_CHECK_TIMEOUT_MS=10000
READER_MODE_TIMEOUT_MS=15000
WAYBACK_TIMEOUT_MS=30000

# Worker Retries
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_DELAY_MS=1000
