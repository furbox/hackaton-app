{
  "manifest_version": 3,
  "name": "URLoft - Guarda tus links",
  "version": "1.0.0",
  "description": "Guarda, organiza y comparte tus links desde cualquier página.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://urloft.site/*",
    "http://localhost:3000/*",
    "https://api.urloft.site/*",
    "https://api-new.urloft.site/*"
  ],
  "action": {
    "default_popup": "popup/html/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "URLoft - Guarda tus links"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
